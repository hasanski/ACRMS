@page "/Account/Manage/ChangePassword"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using ACRMS.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ChangePassword> Logger

<PageTitle>تغيير كلمة المرور</PageTitle>

<style>
    .change-password-page {
        direction: rtl;
    }

    .change-password-card {
        border: 1px solid #edf1f7;
        border-radius: 22px;
        padding: 24px 20px;
        background: #fcfdff;
    }

    .change-password-title {
        margin: 0 0 18px 0;
        font-size: 1.5rem;
        font-weight: 900;
        color: #1f2937;
    }

    .change-password-desc {
        color: #6b7280;
        margin-bottom: 18px;
        line-height: 1.8;
        font-size: .96rem;
    }

    .form-label {
        font-weight: 700;
        color: #374151;
    }

    .form-control {
        border-radius: 14px;
        min-height: 52px;
        border: 1px solid #dbe3f0;
        box-shadow: none;
    }

        .form-control:focus {
            border-color: #7fb0ff;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,.10);
        }

    .btn-main {
        border-radius: 14px;
        min-height: 52px;
        font-weight: 800;
        font-size: 1rem;
        box-shadow: 0 10px 22px rgba(13,110,253,.18);
    }

    .helper-note {
        margin-top: 12px;
        color: #6b7280;
        font-size: .92rem;
        line-height: 1.8;
    }
</style>

<div class="change-password-page">
    <div class="change-password-card">
        <h3 class="change-password-title">تغيير كلمة المرور</h3>
        <div class="change-password-desc">
            من هنا يمكنك تحديث كلمة المرور الخاصة بحسابك. يُفضّل اختيار كلمة مرور قوية تحتوي على أحرف وأرقام ورموز لزيادة الأمان.
        </div>

        <StatusMessage Message="@message" />

        <EditForm Model="Input" FormName="change-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" role="alert" />

            <div class="mb-3">
                <label for="Input.OldPassword" class="form-label">كلمة المرور الحالية</label>
                <InputText type="password"
                           @bind-Value="Input.OldPassword"
                           id="Input.OldPassword"
                           class="form-control"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="أدخل كلمة المرور الحالية" />
                <ValidationMessage For="() => Input.OldPassword" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="Input.NewPassword" class="form-label">كلمة المرور الجديدة</label>
                <InputText type="password"
                           @bind-Value="Input.NewPassword"
                           id="Input.NewPassword"
                           class="form-control"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="أدخل كلمة المرور الجديدة" />
                <ValidationMessage For="() => Input.NewPassword" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="Input.ConfirmPassword" class="form-label">تأكيد كلمة المرور الجديدة</label>
                <InputText type="password"
                           @bind-Value="Input.ConfirmPassword"
                           id="Input.ConfirmPassword"
                           class="form-control"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="أعد إدخال كلمة المرور الجديدة" />
                <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-main">
                    تحديث كلمة المرور
                </button>
            </div>

            <div class="helper-note">
                تأكد من تذكر كلمة المرور الجديدة بعد حفظ التعديلات.
            </div>
        </EditForm>
    </div>
</div>

@code {
    private string? message;
    private ApplicationUser user = default!;
    private bool hasPassword;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        hasPassword = await UserManager.HasPasswordAsync(user);
        if (!hasPassword)
        {
            RedirectManager.RedirectTo("Account/Manage/SetPassword");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var changePasswordResult = await UserManager.ChangePasswordAsync(user, Input.OldPassword, Input.NewPassword);
        if (!changePasswordResult.Succeeded)
        {
            message = $"خطأ: {string.Join("، ", changePasswordResult.Errors.Select(error => error.Description))}";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");

        RedirectManager.RedirectToCurrentPageWithStatus("تم تغيير كلمة المرور بنجاح.", HttpContext);
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "كلمة المرور الحالية مطلوبة")]
        [DataType(DataType.Password)]
        [Display(Name = "كلمة المرور الحالية")]
        public string OldPassword { get; set; } = "";

        [Required(ErrorMessage = "كلمة المرور الجديدة مطلوبة")]
        [StringLength(100, ErrorMessage = "يجب أن تكون {0} بين {2} و {1} حرفًا.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "كلمة المرور الجديدة")]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "تأكيد كلمة المرور الجديدة")]
        [Compare("NewPassword", ErrorMessage = "كلمة المرور الجديدة وتأكيدها غير متطابقين.")]
        public string ConfirmPassword { get; set; } = "";
    }
}