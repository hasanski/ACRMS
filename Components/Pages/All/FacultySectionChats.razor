@page "/faculty/section-chats"
@using System.Security.Claims
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@inject ISectionRepository _sectionRepo
@inject IChatRepository _chatRepo
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime _JS
@attribute [Authorize(Roles = "Faculty")]

<PageTitle>محادثات الشعب</PageTitle>

<style>
    .hover-bg-light:hover {
        background-color: #f8f9fa !important;
    }
    .bulk-message-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
        color: white;
    }
    .bulk-message-card h5 {
        color: white;
        margin-bottom: 12px;
    }
    .bulk-message-card .form-control,
    .bulk-message-card .form-control:focus {
        background: rgba(255,255,255,0.95);
        border: none;
    }
</style>

<div class="container py-4" dir="rtl">
    <div class="bulk-message-card shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0"><i class="bi bi-broadcast me-2"></i>إرسال رسالة جماعية</h5>
            <button class="btn btn-sm btn-light" @onclick="ToggleSelectAll">
                @(_allSelected ? "إلغاء تحديد الكل" : "تحديد الكل")
            </button>
        </div>
        <div class="mb-2">
            <input type="text"
                   class="form-control"
                   @bind="_searchText"
                   @bind:event="oninput"
                   placeholder="بحث بالشعبة أو المادة..." />
        </div>
        <div class="row">
            <div class="col-md-8">
                <textarea class="form-control"
                          @bind="_bulkMessage"
                          @oninput="OnMessageInput"
                          rows="2"
                          placeholder="اكتب الرسالة هنا..."></textarea>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="button" class="btn btn-success w-100"
                        @onclick="SendBulkMessage"
                        disabled="@(!CanSendBulkMessage)">
                    <i class="bi bi-send me-2"></i>إرسال (@_selectedSections.Count شعبة)
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <h4 class="mb-3">محادثات الشعب</h4>

            @if (_filteredItems.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width:50px;">
                                    <input type="checkbox"
                                           checked="@_allSelected"
                                           @onchange="ToggleSelectAll" />
                                </th>
                                <th>#</th>
                                <th>الشعبة</th>
                                <th>المادة</th>
                                <th>ظهور للطلاب</th>
                                <th>السماح بالرد</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _filteredItems)
                            {
                                <tr class="hover-bg-light" style="cursor:pointer;" @onclick="@(async _ => await ToggleSectionSelection(item))">
                                    <td @onclick:stopPropagation>
                                        <input type="checkbox"
                                               checked="@_selectedSections.Contains(item.Section.Id)"
                                               @onchange="@(async _ => await ToggleSectionSelection(item))"
                                               @onclick:stopPropagation />
                                    </td>
                                    <td>@item.Section.Id</td>
                                    <td>@item.Section.SectionName</td>
                                    <td>@(item.Section.Course?.CourseName)</td>
                                    <td @onclick:stopPropagation>
                                        <input type="checkbox"
                                               checked="@item.IsVisibleToStudents"
                                               @onchange="async e => await UpdateVisibility(item, e)"
                                               @onclick:stopPropagation />
                                    </td>
                                    <td @onclick:stopPropagation>
                                        <input type="checkbox"
                                               checked="@item.StudentsCanReply"
                                               disabled="@(!item.IsVisibleToStudents)"
                                               @onchange="async e => await UpdateReplyPermission(item, e)"
                                               @onclick:stopPropagation />
                                    </td>
                                    <td class="text-end" @onclick:stopPropagation>
                                        <button class="btn btn-sm btn-primary"
                                                @onclick="() => OpenSectionChat(item.ConversationId)">
                                            فتح المحادثة
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">@(_items.Any() ? "لا توجد نتائج مطابقة للبحث" : "لا توجد شعب مرتبطة بك.")</div>
            }
        </div>
    </div>
</div>

@code {
    private string _facultyId = string.Empty;
    private List<SectionChatItem> _items = new();
    private List<int> _selectedSections = new();
    private string _bulkMessage = string.Empty;
    private string _searchText = string.Empty;
    private bool _allSelected = false;

    private bool CanSendBulkMessage =>
        !string.IsNullOrWhiteSpace(_bulkMessage) && _selectedSections.Any();

    private List<SectionChatItem> _filteredItems =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _items
            : _items.Where(i =>
                i.Section.SectionName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (i.Section.Course?.CourseName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();

    private class SectionChatItem
    {
        public Section Section { get; set; } = default!;
        public int ConversationId { get; set; }
        public bool IsVisibleToStudents { get; set; }
        public bool StudentsCanReply { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _facultyId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        await Load();
    }

    private async Task Load()
    {
        var allSections = await _sectionRepo.ListAsync();
        var mySections = allSections.Where(s => s.FacultyMemberId == _facultyId).ToList();

        _items = new();

        foreach (var section in mySections)
        {
            var conversationId = await _chatRepo.CreateSectionConversationIfNotExistsAsync(section.Id, _facultyId);
            var conversation = await _chatRepo.GetConversationByIdAsync(conversationId);

            _items.Add(new SectionChatItem
            {
                Section = section,
                ConversationId = conversationId,
                IsVisibleToStudents = conversation?.IsVisibleToStudents ?? true,
                StudentsCanReply = conversation?.StudentsCanReply ?? false
            });
        }

        _allSelected = false;
    }

    private void ToggleSelectAll()
    {
        if (_allSelected)
        {
            _selectedSections.Clear();
        }
        else
        {
            _selectedSections = _filteredItems.Select(i => i.Section.Id).ToList();
        }
        _allSelected = !_allSelected;

        StateHasChanged();
    }

    private async Task ToggleSectionSelection(SectionChatItem item)
    {
        if (_selectedSections.Contains(item.Section.Id))
        {
            _selectedSections.Remove(item.Section.Id);
        }
        else
        {
            _selectedSections.Add(item.Section.Id);
        }

        _allSelected = _filteredItems.Count > 0 && _filteredItems.All(i => _selectedSections.Contains(i.Section.Id));
        StateHasChanged();
    }

    private void OnMessageInput(ChangeEventArgs e)
    {
        _bulkMessage = e.Value?.ToString() ?? string.Empty;
    }

    private async Task SendBulkMessage()
    {
        if (string.IsNullOrWhiteSpace(_bulkMessage) || !_selectedSections.Any())
        {
            await _JS.ToastrError("الرجاء كتابة رسالة واختيار شعب على الأقل");
            return;
        }

        try
        {
            var successCount = 0;

            foreach (var item in _items.Where(i => _selectedSections.Contains(i.Section.Id)))
            {
                try
                {
                    await _chatRepo.SendMessageAsync(item.ConversationId, _facultyId, _bulkMessage);
                    successCount++;
                }
                catch
                {
                    // Continue even if one fails
                }
            }

            await _JS.ToastrSuccess($"تم إرسال الرسالة إلى {successCount} شعبة بنجاح");
            _bulkMessage = string.Empty;
            _selectedSections.Clear();
            _allSelected = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"حدث خطأ أثناء الإرسال: {ex.Message}");
        }
    }

    private async Task OpenSectionChat(int conversationId)
    {
        NavigationManager.NavigateTo($"/chat?conversationId={conversationId}");
    }

    private async Task UpdateVisibility(SectionChatItem item, ChangeEventArgs e)
    {
        var value = e.Value is bool b && b;

        item.IsVisibleToStudents = value;

        if (!value)
        {
            item.StudentsCanReply = false;
        }

        await _chatRepo.UpdateSectionConversationSettingsAsync(
            item.ConversationId,
            item.IsVisibleToStudents,
            item.StudentsCanReply);

        await _JS.ToastrSuccess("تم تحديث إعدادات المحادثة");
    }

    private async Task UpdateReplyPermission(SectionChatItem item, ChangeEventArgs e)
    {
        var value = e.Value is bool b && b;

        item.StudentsCanReply = value;

        await _chatRepo.UpdateSectionConversationSettingsAsync(
            item.ConversationId,
            item.IsVisibleToStudents,
            item.StudentsCanReply);

        await _JS.ToastrSuccess("تم تحديث صلاحية الرد");
    }
}