@page "/admin/sections"
@using System.ComponentModel.DataAnnotations
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@inject ISectionRepository _repo
@inject IJSRuntime _JS
@attribute [Authorize(Roles = "Admin")]

<ConfirmationModal @ref="_deleteModal"
                   ModalId="deleteSectionModal"
                   Title="تأكيد حذف الشعبة"
                   Message="@_deleteMessage"
                   ConfirmButtonText="حذف"
                   ConfirmButtonClass="btn-danger"
                   OnConfirm="ConfirmDeleteAsync" />

<PageTitle>إدارة الشعب</PageTitle>

<style>
    .wrap {
        max-width: 1100px;
        margin: auto;
        padding: 16px;
    }

    .card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .head {
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        background: linear-gradient(180deg,#fff 0%,#fafafa 100%);
    }

    .title {
        margin: 0;
        font-weight: 900;
        font-size: 18px;
    }

    .badge-soft {
        background: #f3f6ff;
        border: 1px solid #dfe8ff;
        color: #0d6efd;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        white-space: nowrap;
    }

    .body {
        padding: 16px;
    }

    .section {
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
    }

    .sec-title {
        font-weight: 900;
        margin: 0 0 12px 0;
        font-size: 15px;
        color: #222;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        align-items: end;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }

    .muted {
        color: #666;
        font-size: 13px;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .input-validation-error {
        border: 2px solid #dc3545 !important;
        background: #fff5f5;
    }

    .edit-banner {
        background: #fff8e6;
        border: 1px solid #ffe08a;
        color: #7a5a00;
        border-radius: 12px;
        padding: 10px 14px;
        margin-bottom: 14px;
        font-weight: 700;
    }

    .empty-box {
        text-align: center;
        padding: 24px;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        background: #fafafa;
        color: #666;
        font-size: 15px;
    }

    .active-row {
        background-color: #fffdf3;
    }
</style>

<div class="wrap" dir="rtl">
    <div class="card">
        <div class="head">
            <h3 class="title">إدارة الشعب</h3>
            <span class="badge-soft">إضافة / تعديل / حذف</span>
        </div>

        <div class="body">
            @if (_editMode)
            {
                <div class="edit-banner">
                    أنت الآن في وضع تعديل شعبة.
                </div>
            }

            <div class="section">
                <div class="sec-title">@(_editMode ? "تعديل شعبة" : "إضافة شعبة جديدة")</div>

                <EditForm EditContext="_editContext" OnValidSubmit="Save" FormName="SectionForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="grid">
                        <div>
                            <label class="form-label">اسم الشعبة</label>
                            <InputText class="form-control" @bind-Value="_form.SectionName" />
                            <ValidationMessage For="@(() => _form.SectionName)" />
                        </div>

                        <div>
                            <label class="form-label">الكلية</label>
                            <select class="form-control" @onchange="OnFacultyChanged">
                                <option value="">-- اختر الكلية --</option>
                                @foreach (var faculty in _faculties)
                                {
                                    <option value="@faculty" selected="@(faculty == _selectedFacultyName)">
                                        @faculty
                                    </option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="form-label">القسم</label>
                            <select class="form-control" @onchange="OnDepartmentChanged" disabled="@(!_filteredDepartments.Any())">
                                <option value="">-- اختر القسم --</option>
                                @foreach (var department in _filteredDepartments)
                                {
                                    <option value="@department.Id" selected="@(department.Id == _selectedDepartmentId)">
                                        @department.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="form-label">المادة</label>
                            <InputSelect class="form-control" @bind-Value="_form.CourseId" disabled="@(!_filteredCourses.Any())">
                                <option value="">-- اختر المادة --</option>
                                @foreach (var course in _filteredCourses)
                                {
                                    <option value="@course.Id">@course.CourseName (@course.CourseCode)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _form.CourseId)" />
                        </div>

                        <div>
                            <label class="form-label">المدرس</label>
                            <InputSelect class="form-control" @bind-Value="_form.FacultyMemberId" disabled="@(!_filteredFacultyMembers.Any())">
                                <option value="">-- اختر المدرس --</option>
                                @foreach (var facultyMember in _filteredFacultyMembers)
                                {
                                    <option value="@facultyMember.Id">@facultyMember.FullName</option>
                                }
                            </InputSelect>
                        </div>

                        <div style="grid-column: 1 / -1; display:flex; gap:10px; flex-wrap:wrap;">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">
                                @(_saving ? "جارٍ الحفظ..." : (_editMode ? "حفظ التعديل" : "إضافة"))
                            </button>

                            @if (_editMode)
                            {
                                <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">
                                    إلغاء
                                </button>
                            }
                        </div>
                    </div>
                </EditForm>
            </div>

            <hr />

            <div class="section">
                <div class="sec-title">قائمة الشعب</div>

                <div class="grid" style="grid-template-columns: 1fr 1fr 1fr 180px;">
                    <div>
                        <label class="form-label">بحث</label>
                        <input class="form-control" @bind="_q" @bind:event="oninput" placeholder="ابحث باسم الشعبة أو المادة أو المدرس..." />
                    </div>

                    <div>
                        <label class="form-label">فلترة حسب الكلية</label>
                        <select class="form-control" @onchange="OnTableFacultyChanged">
                            <option value="">-- كل الكليات --</option>
                            @foreach (var faculty in _faculties)
                            {
                                <option value="@faculty" selected="@(faculty == _tableFacultyFilter)">
                                    @faculty
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">فلترة حسب القسم</label>
                        <InputSelect class="form-control" @bind-Value="_tableDepartmentFilter" disabled="@(!_tableFilteredDepartments.Any())">
                            <option value="">-- كل الأقسام --</option>
                            @foreach (var department in _tableFilteredDepartments)
                            {
                                <option value="@department.Id">@department.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <button class="btn btn-success w-100" @onclick="Load">تحديث</button>
                    </div>
                </div>

                <div class="muted" style="margin-top:8px;">عدد النتائج: @Filtered().Count()</div>

                @if (Filtered().Any())
                {
                    <div class="table-responsive" style="margin-top:10px;">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th style="width:70px;">#</th>
                                    <th>اسم الشعبة</th>
                                    <th>المادة</th>
                                    <th>رمز المادة</th>
                                    <th>المدرس</th>
                                    <th>الكلية</th>
                                    <th>القسم</th>
                                    <th style="width:220px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var x in Filtered())
                                {
                                    <tr class="@(IsEditingRow(x.Id) ? "active-row" : "")">
                                        <td><strong>@x.Id</strong></td>
                                        <td>@x.SectionName</td>
                                        <td>@x.Course?.CourseName</td>
                                        <td>@x.Course?.CourseCode</td>
                                        <td>@(x.FacultyMember?.FullName ?? "-")</td>
                                        <td>@x.Course?.Department?.FacultyName</td>
                                        <td>@x.Course?.Department?.Name</td>
                                        <td class="text-end">
                                            <button class="btn btn-outline-warning btn-sm" @onclick="async () => await StartEdit(x)">
                                                تعديل
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="async () => await AskDelete(x.Id, x.SectionName)">
                                                حذف
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-box" style="margin-top: 12px;">
                        لا توجد شعب مضافة حاليًا.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private class SectionForm
    {
        public int? Id { get; set; }

        [Required(ErrorMessage = "اسم الشعبة مطلوب")]
        [MaxLength(100, ErrorMessage = "الحد الأقصى 100 حرف")]
        public string? SectionName { get; set; }

        [Required(ErrorMessage = "المادة مطلوبة")]
        [Range(1, int.MaxValue, ErrorMessage = "اختر المادة")]
        public int? CourseId { get; set; }

        public string? FacultyMemberId { get; set; }
    }

    private ConfirmationModal? _deleteModal;
    private int _deleteSectionId;
    private string _deleteSectionName = string.Empty;
    private string _deleteMessage => $"هل أنت متأكد من حذف الشعبة \"{_deleteSectionName}\"؟";

    private bool _saving = false;
    private bool _editMode = false;
    private string _q = string.Empty;

    private List<Section> _items = new();
    private List<Department> _departments = new();
    private List<Course> _courses = new();
    private List<ApplicationUser> _facultyMembers = new();

    private List<string> _faculties = new();
    private List<Department> _filteredDepartments = new();
    private List<Course> _filteredCourses = new();

    private string _selectedFacultyName = string.Empty;
    private int? _selectedDepartmentId = null;

    private string _tableFacultyFilter = string.Empty;
    private int? _tableDepartmentFilter = null;
    private List<Department> _tableFilteredDepartments = new();

    private SectionForm _form = new();
    private EditContext _editContext = default!;
    private List<ApplicationUser> _filteredFacultyMembers = new();

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        await Load();
    }

    private void ResetForm()
    {
        _form = new SectionForm();
        _editContext = new EditContext(_form);
        _editMode = false;
        _selectedFacultyName = string.Empty;
        _selectedDepartmentId = null;
        _filteredDepartments = new();
        _filteredCourses = new();
        _filteredFacultyMembers = new();
    }
    private void ApplyFacultyMembersFilter()
    {
        if (string.IsNullOrWhiteSpace(_selectedFacultyName))
        {
            _filteredFacultyMembers = new();
            _form.FacultyMemberId = null;
            return;
        }

        _filteredFacultyMembers = _facultyMembers
            .Where(f => f.Department != null && f.Department.FacultyName == _selectedFacultyName)
            .OrderBy(f => f.FullName)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_form.FacultyMemberId) &&
            !_filteredFacultyMembers.Any(f => f.Id == _form.FacultyMemberId))
        {
            _form.FacultyMemberId = null;
        }
    }

    private async Task Load()
    {
        _items = await _repo.ListAsync();
        _departments = await _repo.GetDepartmentsAsync();
        _courses = await _repo.GetCoursesAsync();
        _facultyMembers = await _repo.GetFacultyMembersAsync();

        _faculties = _departments
            .Where(d => !string.IsNullOrWhiteSpace(d.FacultyName))
            .Select(d => d.FacultyName!.Trim())
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        ApplyDepartmentFilter();
        ApplyCourseFilter();
        ApplyFacultyMembersFilter();
        ApplyTableDepartmentFilter();

        StateHasChanged();
    }

    private void ApplyDepartmentFilter()
    {
        if (string.IsNullOrWhiteSpace(_selectedFacultyName))
        {
            _filteredDepartments = new();
            _selectedDepartmentId = null;
            return;
        }

        _filteredDepartments = _departments
            .Where(d => d.FacultyName == _selectedFacultyName)
            .OrderBy(d => d.Name)
            .ToList();

        if (_selectedDepartmentId.HasValue && !_filteredDepartments.Any(d => d.Id == _selectedDepartmentId.Value))
            _selectedDepartmentId = null;
    }

    private void ApplyCourseFilter()
    {
        if (!_selectedDepartmentId.HasValue)
        {
            _filteredCourses = new();
            _form.CourseId = null;
            return;
        }

        _filteredCourses = _courses
            .Where(c => c.DepartmentId == _selectedDepartmentId.Value)
            .OrderBy(c => c.CourseName)
            .ToList();

        if (_form.CourseId.HasValue && !_filteredCourses.Any(c => c.Id == _form.CourseId.Value))
            _form.CourseId = null;
    }

    private void ApplyTableDepartmentFilter()
    {
        if (string.IsNullOrWhiteSpace(_tableFacultyFilter))
        {
            _tableFilteredDepartments = new();
            _tableDepartmentFilter = null;
            return;
        }

        _tableFilteredDepartments = _departments
            .Where(d => d.FacultyName == _tableFacultyFilter)
            .OrderBy(d => d.Name)
            .ToList();

        if (_tableDepartmentFilter.HasValue && !_tableFilteredDepartments.Any(d => d.Id == _tableDepartmentFilter.Value))
            _tableDepartmentFilter = null;
    }

    private Task OnFacultyChanged(ChangeEventArgs e)
    {
        _selectedFacultyName = e.Value?.ToString() ?? string.Empty;
        _selectedDepartmentId = null;
        _form.CourseId = null;
        _form.FacultyMemberId = null;

        ApplyDepartmentFilter();
        ApplyCourseFilter();
        ApplyFacultyMembersFilter();
        return Task.CompletedTask;
    }

    private Task OnDepartmentChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            _selectedDepartmentId = id;
        else
            _selectedDepartmentId = null;

        _form.CourseId = null;
        ApplyCourseFilter();
        return Task.CompletedTask;
    }

    private Task OnTableFacultyChanged(ChangeEventArgs e)
    {
        _tableFacultyFilter = e.Value?.ToString() ?? string.Empty;
        _tableDepartmentFilter = null;
        ApplyTableDepartmentFilter();
        return Task.CompletedTask;
    }

    private IEnumerable<Section> Filtered()
    {
        IEnumerable<Section> q = _items;

        if (!string.IsNullOrWhiteSpace(_q))
        {
            var s = _q.Trim();
            q = q.Where(x =>
                (x.SectionName ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (x.Course?.CourseName ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (x.Course?.CourseCode ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (x.FacultyMember?.FullName ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_tableFacultyFilter))
        {
            q = q.Where(x => x.Course?.Department?.FacultyName == _tableFacultyFilter);
        }

        if (_tableDepartmentFilter.HasValue)
        {
            q = q.Where(x => x.Course?.DepartmentId == _tableDepartmentFilter.Value);
        }

        return q.OrderByDescending(x => x.Id);
    }

    private bool IsEditingRow(int id) => _editMode && _form.Id == id;

    private Task StartEdit(Section x)
    {
        _editMode = true;
        _selectedFacultyName = x.Course?.Department?.FacultyName ?? string.Empty;
        _selectedDepartmentId = x.Course?.DepartmentId;

        _form = new SectionForm
        {
            Id = x.Id,
            SectionName = x.SectionName,
            CourseId = x.CourseId,
            FacultyMemberId = x.FacultyMemberId
        };

        _editContext = new EditContext(_form);

        ApplyDepartmentFilter();
        ApplyCourseFilter();
        ApplyFacultyMembersFilter();

        return Task.CompletedTask;
    }

    private void CancelEdit() => ResetForm();

    private async Task Save()
    {
        if (_saving) return;
        _saving = true;

        try
        {
            var sectionName = (_form.SectionName ?? string.Empty).Trim();

            if (await _repo.ExistsByNameInCourseAsync(sectionName, _form.CourseId!.Value, _form.Id))
            {
                await _JS.ToastrError("اسم الشعبة موجود مسبقًا ضمن نفس المادة");
                return;
            }

            if (_form.Id.HasValue)
            {
                await _repo.UpdateAsync(new Section
                {
                    Id = _form.Id.Value,
                    SectionName = sectionName,
                    CourseId = _form.CourseId.Value,
                    FacultyMemberId = string.IsNullOrWhiteSpace(_form.FacultyMemberId) ? null : _form.FacultyMemberId
                });

                await _JS.ToastrSuccess("تم تعديل الشعبة بنجاح");
            }
            else
            {
                await _repo.CreateAsync(new Section
                {
                    SectionName = sectionName,
                    CourseId = _form.CourseId.Value,
                    FacultyMemberId = string.IsNullOrWhiteSpace(_form.FacultyMemberId) ? null : _form.FacultyMemberId
                });

                await _JS.ToastrSuccess("تمت إضافة الشعبة بنجاح");
            }

            ResetForm();
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"فشلت العملية: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AskDelete(int id, string name)
    {
        _deleteSectionId = id;
        _deleteSectionName = name;

        if (_deleteModal is not null)
            await _deleteModal.ShowAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            var hasDependencies = await _repo.HasDependenciesAsync(_deleteSectionId);

            if (hasDependencies)
            {
                await _JS.ToastrError("لا يمكن حذف الشعبة لأنها مرتبطة ببيانات أخرى");
                return;
            }

            await _repo.DeleteAsync(_deleteSectionId);
            await _JS.ToastrSuccess("تم حذف الشعبة بنجاح");

            if (_editMode && _form.Id == _deleteSectionId)
                ResetForm();

            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر حذف الشعبة: {ex.Message}");
        }
    }
}