@page "/faculty/grade-review-requests"
@using System.Security.Claims
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@using static ACRMS.Data.Enums
@inject IGradeReviewRequestRepository _repo
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime _JS
@attribute [Authorize(Roles = "Faculty")]

<PageTitle>طلبات مراجعة العلامات الواردة</PageTitle>

<style>
    .wrap {
        max-width: 1200px;
        margin: auto;
        padding: 16px;
    }

    .card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .head {
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        background: linear-gradient(180deg,#fff 0%,#fafafa 100%);
    }

    .title {
        margin: 0;
        font-weight: 900;
        font-size: 18px;
    }

    .badge-soft {
        background: #f3f6ff;
        border: 1px solid #dfe8ff;
        color: #0d6efd;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        white-space: nowrap;
    }

    .body {
        padding: 16px;
    }

    .section {
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .empty-box {
        text-align: center;
        padding: 24px;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        background: #fafafa;
        color: #666;
        font-size: 15px;
    }

    .pill {
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        border: 1px solid #eee;
        display: inline-block;
    }

    .pill-pending {
        background: #fff3cd;
        border-color: #ffe69c;
        color: #856404;
    }

    .pill-approved {
        background: #d1e7dd;
        border-color: #a3cfbb;
        color: #0f5132;
    }

    .pill-rejected {
        background: #f8d7da;
        border-color: #f1aeb5;
        color: #842029;
    }
</style>

<div class="wrap" dir="rtl">
    <div class="card">
        <div class="head">
            <h3 class="title">طلبات مراجعة العلامات الواردة</h3>
            <span class="badge-soft">مراجعة / قبول / رفض</span>
        </div>

        <div class="body">
            <div class="section">
                @if (_items.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>الرقم المرجعي</th>
                                    <th>الطالب</th>
                                    <th>المادة</th>
                                    <th>التقييم</th>
                                    <th>العلامة</th>
                                    <th>سبب الطلب</th>
                                    <th>الحالة</th>
                                    <th>ملاحظة الدكتور</th>
                                    <th style="width:260px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr>
                                        <td>@item.ReferenceNumber</td>
                                        <td>@item.Student?.FullName</td>
                                        <td>@item.Course?.CourseName</td>
                                        <td>@item.AssessmentName</td>
                                        <td>@item.CurrentMark</td>
                                        <td>@item.RequestReason</td>
                                        <td>
                                            <span class="pill @GetStatusClass(item.Status)">
                                                @GetStatusText(item.Status)
                                            </span>
                                        </td>
                                        <td>@item.FacultyNote</td>
                                        <td class="text-end">
                                            @if (item.Status == RequestStatus.Pending)
                                            {
                                                <button class="btn btn-outline-success btn-sm"
                                                        @onclick="@(async () => await UpdateStatus(item.Id, RequestStatus.Approved, "تمت مراجعة العلامة وقبول الطلب"))">
                                                    قبول
                                                </button>

                                                <button class="btn btn-outline-warning btn-sm"
                                                        @onclick="@(async () => await PromptReject(item.Id))">
                                                    رفض
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-box">لا توجد طلبات واردة حاليًا.</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string _facultyId = string.Empty;
    private List<GradeReviewRequest> _items = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _facultyId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        await Load();
    }

    private async Task Load()
    {
        _items = await _repo.GetFacultyRequestsAsync(_facultyId);
        StateHasChanged();
    }

    private async Task UpdateStatus(int id, RequestStatus status, string? note)
    {
        try
        {
            await _repo.UpdateStatusAsync(id, status, note);
            await _JS.ToastrSuccess("تم تحديث حالة الطلب");
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر تحديث الحالة: {ex.Message}");
        }
    }

    private async Task PromptReject(int id)
    {
        var response = await _JS.InvokeAsync<string>("prompt", "أدخل سبب الرفض:", "تم رفض الطلب");
        if (response is null) return;

        try
        {
            await _repo.UpdateStatusAsync(id, RequestStatus.Rejected, response);
            await _JS.ToastrSuccess("تم رفض الطلب");
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر تحديث الحالة: {ex.Message}");
        }
    }

    private static string GetStatusText(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "قيد الانتظار",
        RequestStatus.Approved => "مقبول",
        RequestStatus.Rejected => "مرفوض",
        _ => status.ToString()
    };

    private static string GetStatusClass(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "pill-pending",
        RequestStatus.Approved => "pill-approved",
        RequestStatus.Rejected => "pill-rejected",
        _ => "pill-pending"
    };
}