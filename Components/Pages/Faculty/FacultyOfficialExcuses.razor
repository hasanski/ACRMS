@page "/faculty/official-excuses"
@using System.Security.Claims
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@using static ACRMS.Data.Enums
@inject IOfficialExcuseRepository _repo
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime _JS
@attribute [Authorize(Roles = "Faculty")]

<PageTitle>الأعذار الرسمية الواردة</PageTitle>

<style>
    .wrap {
        max-width: 1200px;
        margin: auto;
        padding: 16px;
    }

    .card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .head {
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        background: linear-gradient(180deg,#fff 0%,#fafafa 100%);
    }

    .title {
        margin: 0;
        font-weight: 900;
        font-size: 18px;
    }

    .badge-soft {
        background: #f3f6ff;
        border: 1px solid #dfe8ff;
        color: #0d6efd;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        white-space: nowrap;
    }

    .body {
        padding: 16px;
    }

    .section {
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .empty-box {
        text-align: center;
        padding: 24px;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        background: #fafafa;
        color: #666;
        font-size: 15px;
    }

    .pill {
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        border: 1px solid #eee;
        display: inline-block;
    }

    .pill-pending {
        background: #fff3cd;
        border-color: #ffe69c;
        color: #856404;
    }

    .pill-approved {
        background: #d1e7dd;
        border-color: #a3cfbb;
        color: #0f5132;
    }

    .pill-rejected {
        background: #f8d7da;
        border-color: #f1aeb5;
        color: #842029;
    }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
        padding: 16px;
        backdrop-filter: blur(2px);
    }

    .modal-card-custom {
        width: 100%;
        max-width: 560px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        border: 1px solid #ececec;
        overflow: hidden;
        animation: popIn .18s ease-out;
    }

    .modal-head-custom {
        padding: 16px 18px;
        border-bottom: 1px solid #f0f0f0;
        background: linear-gradient(180deg, #fff 0%, #fafafa 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .modal-title-custom {
        margin: 0;
        font-size: 18px;
        font-weight: 900;
        color: #222;
    }

    .modal-body-custom {
        padding: 18px;
    }

    .modal-text-custom {
        color: #555;
        margin-bottom: 12px;
        font-size: 14px;
    }

    .modal-footer-custom {
        padding: 14px 18px;
        border-top: 1px solid #f0f0f0;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        background: #fcfcfc;
    }

    .reject-textarea {
        min-height: 130px;
        resize: vertical;
        border-radius: 14px;
        border: 1px solid #dcdcdc;
        padding: 12px 14px;
        font-size: 14px;
        box-shadow: none;
    }

        .reject-textarea:focus {
            border-color: #f0ad4e;
            box-shadow: 0 0 0 0.2rem rgba(240, 173, 78, 0.15);
            outline: none;
        }

    .reject-error {
        color: #b42318;
        font-size: 13px;
        margin-top: 8px;
        font-weight: 700;
    }

    .btn-soft-secondary {
        border-radius: 12px;
        padding: 8px 18px;
        font-weight: 700;
    }

    .btn-reject-confirm {
        border-radius: 12px;
        padding: 8px 18px;
        font-weight: 800;
    }

    @@keyframes popIn {
        from

    {
        opacity: 0;
        transform: translateY(8px) scale(.98);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }
</style>

<div class="wrap" dir="rtl">
    <div class="card">
        <div class="head">
            <h3 class="title">الأعذار الرسمية الواردة</h3>
            <span class="badge-soft">مراجعة / قبول / رفض</span>
        </div>

        <div class="body">
            <div class="section">
                @if (_items.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>الرقم المرجعي</th>
                                    <th>الطالب</th>
                                    <th>العنوان</th>
                                    <th>الوصف</th>
                                    <th>المرفق</th>
                                    <th>الحالة</th>
                                    <th>ملاحظة المراجع</th>
                                    <th style="width:260px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr>
                                        <td>@item.ReferenceNumber</td>
                                        <td>@item.Student?.FullName</td>
                                        <td>@item.Title</td>
                                        <td>@item.Description</td>
                                        <td><a href="@item.AttachmentPath" target="_blank">فتح المرفق</a></td>
                                        <td>
                                            <span class="pill @GetStatusClass(item.Status)">
                                                @GetStatusText(item.Status)
                                            </span>
                                        </td>
                                        <td>@item.ReviewerNote</td>
                                        <td class="text-end">
                                            @if (item.Status == RequestStatus.Pending)
                                            {
                                                <button class="btn btn-outline-success btn-sm"
                                                        @onclick="@(async () => await UpdateStatus(item.Id, RequestStatus.Approved, "تم قبول العذر"))">
                                                    قبول
                                                </button>

                                                <button class="btn btn-outline-warning btn-sm"
                                                        @onclick="() => OpenRejectDialog(item.Id)">
                                                    رفض
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-box">لا توجد أعذار واردة حاليًا.</div>
                }
            </div>
        </div>
    </div>
</div>

@if (_showRejectDialog)
{
    <div class="modal-backdrop-custom" dir="rtl">
        <div class="modal-card-custom">
            <div class="modal-head-custom">
                <h5 class="modal-title-custom">رفض العذر الرسمي</h5>
                <button type="button" class="btn-close" @onclick="CloseRejectDialog"></button>
            </div>

            <div class="modal-body-custom">
                <div class="modal-text-custom">
                    الرجاء إدخال سبب الرفض بشكل واضح ليظهر للطالب.
                </div>

                <textarea class="form-control reject-textarea"
                          placeholder="اكتب سبب الرفض هنا..."
                          @bind="_rejectReason"></textarea>

                @if (_showRejectValidation)
                {
                    <div class="reject-error">سبب الرفض مطلوب.</div>
                }
            </div>

            <div class="modal-footer-custom">
                <button class="btn btn-light btn-soft-secondary" @onclick="CloseRejectDialog">
                    إلغاء
                </button>

                <button class="btn btn-warning btn-reject-confirm" @onclick="ConfirmRejectAsync">
                    تأكيد الرفض
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _facultyId = string.Empty;
    private List<OfficialExcuse> _items = new();
    private bool _showRejectDialog;
    private bool _showRejectValidation;
    private int _selectedRejectId;
    private string _rejectReason = string.Empty;

    private void OpenRejectDialog(int id)
    {
        _selectedRejectId = id;
        _rejectReason = string.Empty;
        _showRejectValidation = false;
        _showRejectDialog = true;
    }

    private void CloseRejectDialog()
    {
        _showRejectDialog = false;
        _showRejectValidation = false;
        _selectedRejectId = 0;
        _rejectReason = string.Empty;
    }

    private async Task ConfirmRejectAsync()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            _showRejectValidation = true;
            return;
        }

        try
        {
            await _repo.UpdateStatusAsync(_selectedRejectId, RequestStatus.Rejected, _rejectReason.Trim());
            await _JS.ToastrSuccess("تم رفض العذر");
            CloseRejectDialog();
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر تحديث الحالة: {ex.Message}");
        }
    }
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _facultyId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        await Load();
    }

    private async Task Load()
    {
        _items = await _repo.GetFacultyExcusesAsync(_facultyId);
        StateHasChanged();
    }

    private async Task UpdateStatus(int id, RequestStatus status, string? note)
    {
        try
        {
            await _repo.UpdateStatusAsync(id, status, note);
            await _JS.ToastrSuccess("تم تحديث حالة العذر");
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر تحديث الحالة: {ex.Message}");
        }
    }

    // private async Task PromptReject(int id)
    // {
    //     var response = await _JS.InvokeAsync<string>("prompt", "أدخل سبب الرفض:", "تم رفض العذر");
    //     if (response is null) return;

    //     try
    //     {
    //         await _repo.UpdateStatusAsync(id, RequestStatus.Rejected, response);
    //         await _JS.ToastrSuccess("تم رفض العذر");
    //         await Load();
    //     }
    //     catch (Exception ex)
    //     {
    //         await _JS.ToastrError($"تعذر تحديث الحالة: {ex.Message}");
    //     }
    // }

    private static string GetStatusText(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "قيد الانتظار",
        RequestStatus.Approved => "مقبول",
        RequestStatus.Rejected => "مرفوض",
        _ => status.ToString()
    };

    private static string GetStatusClass(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "pill-pending",
        RequestStatus.Approved => "pill-approved",
        RequestStatus.Rejected => "pill-rejected",
        _ => "pill-pending"
    };
}