@page "/faculty/notifications"
@using System.Security.Claims
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@using static ACRMS.Data.Enums
@inject IAcademicNotificationRepository _repo
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime _JS
@attribute [Authorize(Roles = "Faculty")]

<PageTitle>تنبيهات الدكتور</PageTitle>

<style>
    .wrap {
        max-width: 1100px;
        margin: auto;
        padding: 16px;
    }

    .card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .head {
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        background: linear-gradient(180deg,#fff 0%,#fafafa 100%);
    }

    .title {
        margin: 0;
        font-weight: 900;
        font-size: 18px;
    }

    .badge-soft {
        background: #f3f6ff;
        border: 1px solid #dfe8ff;
        color: #0d6efd;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
    }

    .body {
        padding: 16px;
    }

    .notification-item {
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 12px;
        background: #fff;
    }

    .notification-unread {
        border-right: 4px solid #198754;
        background: #f8fff9;
    }

    .meta {
        color: #666;
        font-size: 13px;
        margin-top: 6px;
    }

    .empty-box {
        text-align: center;
        padding: 24px;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        background: #fafafa;
        color: #666;
        font-size: 15px;
    }
</style>

<div class="wrap" dir="rtl">
    <div class="card">
        <div class="head">
            <h3 class="title">تنبيهاتي</h3>
            <span class="badge-soft">غير المقروء: @_unreadCount</span>
        </div>

        <div class="body">
            <div style="margin-bottom:12px;">
                <button class="btn btn-outline-primary" @onclick="MarkAllAsRead">تعيين الكل كمقروء</button>
            </div>

            @if (_items.Any())
            {
                @foreach (var item in _items)
                {
                    <div class="notification-item @(item.IsRead ? "" : "notification-unread")">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div><strong>@item.Title</strong></div>
                                <div class="mt-1">@item.Message</div>
                                <div class="meta">
                                    الطالب: @item.Student?.FullName |
                                    النوع: @GetTypeText(item.Type) |
                                    التاريخ: @item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </div>
                            </div>

                            @if (!item.IsRead)
                            {
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="@(async () => await MarkAsRead(item.Id))">
                                    تعليم كمقروء
                                </button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-box">لا توجد تنبيهات حاليًا.</div>
            }
        </div>
    </div>
</div>

@code {
    private string _facultyId = string.Empty;
    private List<AcademicNotification> _items = new();
    private int _unreadCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _facultyId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        await Load();
    }

    private async Task Load()
    {
        _items = await _repo.GetFacultyNotificationsAsync(_facultyId);
        _unreadCount = await _repo.GetUnreadCountForFacultyAsync(_facultyId);
        StateHasChanged();
    }

    private async Task MarkAsRead(int id)
    {
        await _repo.MarkAsReadAsync(id);
        await Load();
    }

    private async Task MarkAllAsRead()
    {
        await _repo.MarkAllAsReadForFacultyAsync(_facultyId);
        await _JS.ToastrSuccess("تم تعيين جميع التنبيهات كمقروءة");
        await Load();
    }

    private static string GetTypeText(NotificationType type) => type switch
    {
        NotificationType.General => "عام",
        NotificationType.Announcement => "تعميم",
        NotificationType.MeetingRequest => "طلب موعد",
        NotificationType.OfficialExcuse => "عذر رسمي",
        NotificationType.GradeReview => "مراجعة علامة",
        NotificationType.Appointment => "موعد",
        _ => type.ToString()
    };
}