@page "/student/official-excuses"
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using ACRMS.Data
@using ACRMS.Repository.IRepository
@using Microsoft.AspNetCore.Authorization
@using static ACRMS.Data.Enums
@inject IOfficialExcuseRepository _repo
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime _JS
@using Microsoft.AspNetCore.Components.Forms
@inject IFileUploadService _fileUploadService
@attribute [Authorize(Roles = "Student")]

<ConfirmationModal @ref="_deleteModal"
                   ModalId="deleteStudentExcuseModal"
                   Title="تأكيد حذف العذر"
                   Message="@_deleteMessage"
                   ConfirmButtonText="حذف"
                   ConfirmButtonClass="btn-danger"
                   OnConfirm="ConfirmDeleteAsync" />

<PageTitle>الأعذار الرسمية</PageTitle>

<style>
    .wrap {
        max-width: 1200px;
        margin: auto;
        padding: 16px;
    }

    .card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .head {
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        background: linear-gradient(180deg,#fff 0%,#fafafa 100%);
    }

    .title {
        margin: 0;
        font-weight: 900;
        font-size: 18px;
    }

    .badge-soft {
        background: #f3f6ff;
        border: 1px solid #dfe8ff;
        color: #0d6efd;
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        white-space: nowrap;
    }

    .body {
        padding: 16px;
    }

    .section {
        border: 1px solid #ececec;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
    }

    .sec-title {
        font-weight: 900;
        margin: 0 0 12px 0;
        font-size: 15px;
        color: #222;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        align-items: end;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .empty-box {
        text-align: center;
        padding: 24px;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        background: #fafafa;
        color: #666;
        font-size: 15px;
    }

    .pill {
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
        border: 1px solid #eee;
        display: inline-block;
    }

    .pill-pending {
        background: #fff3cd;
        border-color: #ffe69c;
        color: #856404;
    }

    .pill-approved {
        background: #d1e7dd;
        border-color: #a3cfbb;
        color: #0f5132;
    }

    .pill-rejected {
        background: #f8d7da;
        border-color: #f1aeb5;
        color: #842029;
    }
</style>

<div class="wrap" dir="rtl">
    <div class="card">
        <div class="head">
            <h3 class="title">الأعذار الرسمية</h3>
            <span class="badge-soft">تقديم ومتابعة الأعذار</span>
        </div>

        <div class="body">
            <div class="section">
                <div class="sec-title">تقديم عذر رسمي</div>

                <EditForm EditContext="_editContext" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="grid">
                        <div>
                            <label class="form-label">الدكتور</label>
                            <InputSelect class="form-control" @bind-Value="_form.FacultyId">
                                <option value="">-- اختر الدكتور --</option>
                                @foreach (var faculty in _facultyMembers)
                                {
                                    <option value="@faculty.Id">@faculty.FullName</option>
                                }
                            </InputSelect>
                        </div>

                        <div>
                            <label class="form-label">عنوان العذر</label>
                            <InputText class="form-control" @bind-Value="_form.Title" />
                        </div>

                        <div style="grid-column:1 / -1;">
                            <label class="form-label">وصف العذر</label>
                            <InputTextArea class="form-control" rows="4" @bind-Value="_form.Description" />
                        </div>

                        <div style="grid-column:1 / -1;">
                            <label class="form-label">المرفق (اختياري)</label>
                            <InputFile OnChange="OnFileSelected" class="form-control" />
                            @if (!string.IsNullOrWhiteSpace(_selectedFileName))
                            {
                                <div class="text-muted mt-1">الملف المختار: @_selectedFileName</div>
                            }
                        </div>

                        <div style="grid-column:1 / -1; display:flex; gap:10px; flex-wrap:wrap;">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">
                                @(_saving ? "جارٍ الحفظ..." : "إرسال العذر")
                            </button>

                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">
                                مسح النموذج
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>

            <hr />

            <div class="section">
                <div class="sec-title">أعذاري</div>

                @if (_items.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>الرقم المرجعي</th>
                                    <th>الدكتور</th>
                                    <th>العنوان</th>
                                    <th>الحالة</th>
                                    <th>تاريخ الإرسال</th>
                                    <th>ملاحظة المراجع</th>
                                    <th style="width:120px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    var title = item.Title;

                                    <tr>
                                        <td>@item.ReferenceNumber</td>
                                        <td>@item.Faculty?.FullName</td>
                                        <td>@item.Title</td>
                                        <td>
                                            <span class="pill @GetStatusClass(item.Status)">
                                                @GetStatusText(item.Status)
                                            </span>
                                        </td>
                                        <td>@item.SubmittedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        <td>@item.ReviewerNote</td>
                                        <td class="text-end">
                                            @if (item.Status == RequestStatus.Pending)
                                            {
                                                <button class="btn btn-outline-danger btn-sm"
                                                        @onclick="@(async () => await AskDelete(item.Id, title))">
                                                    حذف
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    <tr>
                                        <td colspan="7" style="background:#fafafa;">
                                            <strong>الوصف:</strong> @item.Description
                                            @if (!string.IsNullOrWhiteSpace(item.AttachmentPath))
                                            {
                                                <div class="mt-1">
                                                    <strong>المرفق:</strong>
                                                    <a href="@item.AttachmentPath" target="_blank">فتح المرفق</a>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-box">لا توجد أعذار مقدمة حاليًا.</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private class OfficialExcuseForm
    {
        [Required(ErrorMessage = "الدكتور مطلوب")]
        public string? FacultyId { get; set; }

        [Required(ErrorMessage = "عنوان العذر مطلوب")]
        [MaxLength(200)]
        public string? Title { get; set; }

        [Required(ErrorMessage = "وصف العذر مطلوب")]
        public string? Description { get; set; }

        public string? AttachmentPath { get; set; }
    }
    private IBrowserFile? _selectedFile;
    private string? _selectedFileName;
    private ConfirmationModal? _deleteModal;
    private int _deleteExcuseId;
    private string _deleteExcuseTitle = string.Empty;
    private string _deleteMessage => $"هل أنت متأكد من حذف العذر \"{_deleteExcuseTitle}\"؟";
    private readonly string[] _allowedExtensions = { ".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx" };
    private bool _saving = false;
    private string _studentId = string.Empty;

    private List<OfficialExcuse> _items = new();
    private List<ApplicationUser> _facultyMembers = new();

    private OfficialExcuseForm _form = new();
    private EditContext _editContext = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        ResetForm();
        await Load();
    }

    private async Task LoadCurrentUser()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _studentId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
    }

    private void ResetForm()
    {
        _form = new OfficialExcuseForm();
        _editContext = new EditContext(_form);
        _selectedFile = null;
        _selectedFileName = null;
    }

    private async Task Load()
    {
        _items = await _repo.GetStudentExcusesAsync(_studentId);
        _facultyMembers = await _repo.GetFacultyAsync();
        StateHasChanged();
    }

    private async Task Save()
    {
        if (_saving) return;
        _saving = true;

        try
        {
            if (_selectedFile is not null)
            {
                var extension = Path.GetExtension(_selectedFile.Name).ToLowerInvariant();

                if (!_allowedExtensions.Contains(extension))
                {
                    await _JS.ToastrError("نوع الملف غير مسموح");
                    _saving = false;
                    return;
                }
            }
            var referenceNumber = await _repo.GenerateReferenceNumberAsync();

            string? uploadedPath = null;

            if (_selectedFile is not null)
            {
                uploadedPath = await _fileUploadService.UploadAsync(_selectedFile, "official-excuses");
            }

            await _repo.CreateAsync(new OfficialExcuse
            {
                ReferenceNumber = referenceNumber,
                StudentId = _studentId,
                FacultyId = _form.FacultyId!,
                Title = (_form.Title ?? string.Empty).Trim(),
                Description = (_form.Description ?? string.Empty).Trim(),
                AttachmentPath = uploadedPath,
                Status = RequestStatus.Pending,
                SubmittedAt = DateTime.UtcNow
            });

            await _JS.ToastrSuccess("تم إرسال العذر بنجاح");
            ResetForm();
            _selectedFile = null;
            _selectedFileName = null;
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"فشلت العملية: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AskDelete(int id, string title)
    {
        _deleteExcuseId = id;
        _deleteExcuseTitle = title;

        if (_deleteModal is not null)
            await _deleteModal.ShowAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            await _repo.DeleteAsync(_deleteExcuseId);
            await _JS.ToastrSuccess("تم حذف العذر بنجاح");
            await Load();
        }
        catch (Exception ex)
        {
            await _JS.ToastrError($"تعذر حذف العذر: {ex.Message}");
        }
    }

    private static string GetStatusText(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "قيد الانتظار",
        RequestStatus.Approved => "مقبول",
        RequestStatus.Rejected => "مرفوض",
        _ => status.ToString()
    };

    private static string GetStatusClass(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "pill-pending",
        RequestStatus.Approved => "pill-approved",
        RequestStatus.Rejected => "pill-rejected",
        _ => "pill-pending"
    };
    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _selectedFileName = _selectedFile?.Name;
    }
}