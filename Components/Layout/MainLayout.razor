@inherits LayoutComponentBase
@* @layout ACRMS.Components.Layout.MainLayout
 *@
 @using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="page" dir="rtl">
    @if (_isAuthenticated && !IsPublicPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <article class="content px-4 py-3">
                @Body
            </article>
        </main>
    }
    else
    {
        <main style="width:100%; min-height:100vh;">
            @Body
        </main>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    حدث خطأ غير متوقع.
    <a href="." class="reload">إعادة التحميل</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isAuthenticated;
    private string _currentPath = string.Empty;

    private bool IsPublicPage =>
        string.IsNullOrWhiteSpace(_currentPath) ||
        _currentPath.Equals("/", StringComparison.OrdinalIgnoreCase) ||
        _currentPath.StartsWith("account", StringComparison.OrdinalIgnoreCase) ||
        _currentPath.StartsWith("account/", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        await UpdateLayoutStateAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await UpdateLayoutStateAsync();
    }

    private async Task UpdateLayoutStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        _currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim().ToLowerInvariant();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await UpdateLayoutStateAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
